							<header class="px-5 py-4 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between">
								<div class="min-w-0 flex items-center gap-2.5">
									<span class="grid h-9 w-9 place-items-center rounded-lg bg-success-50 text-success-700 dark:bg-success-500/15 dark:text-success-500">
										<span class="material-symbols-outlined">visibility</span>
									</span>
									<div class="min-w-0">
										<h3 class="font-semibold text-gray-800 dark:text-white/90">Live preview</h3>
										<p class="text-xs text-gray-400 dark:text-gray-500 truncate">Subject: <span id="preview-subject" class="font-medium text-gray-600 dark:text-gray-300"></span></p>
									</div>
								</div>
								<span class="inline-flex items-center gap-1.5 rounded-full bg-success-50 px-2.5 py-0.5 text-xs font-medium text-success-700 dark:bg-success-500/15 dark:text-success-500">
									<span class="h-1.5 w-1.5 rounded-full bg-success-500 animate-pulse"></span>Live
								</span>
							</header>
							<div class="p-5 flex-1">
								<iframe id="preview-frame" title="Email preview" class="w-full h-[600px] rounded-lg border border-gray-200 bg-white dark:border-gray-800"></iframe>
								<p class="text-xs text-gray-400 dark:text-gray-500 mt-2.5">Preview uses sample values (<code class="px-1 rounded bg-gray-100 dark:bg-white/[0.06]">name → Ava</code>). Real sends personalize per subscriber.</p>
							</div>
						</section>
					</div>
				)}

