			<main class="flex-1 px-4 sm:px-6 lg:px-8 py-6 lg:py-8 w-full max-w-[96rem] mx-auto space-y-6">
				{loadError && (
					<div class="rounded-2xl bg-white border border-error-200 px-5 py-4 text-sm text-error-700 shadow-theme-xs dark:bg-white/[0.03] dark:border-error-500/30 dark:text-error-400">
