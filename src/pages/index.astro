							<code class="px-1.5 py-0.5 rounded bg-warning-100 dark:bg-white/[0.06] text-xs">AWS_ACCESS_KEY_ID</code>,
							<code class="px-1.5 py-0.5 rounded bg-warning-100 dark:bg-white/[0.06] text-xs">AWS_SECRET_ACCESS_KEY</code>.
