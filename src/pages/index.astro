				</div>
			</div>

			<nav class="flex-1 px-4 py-5 space-y-6 overflow-y-auto nice-scroll">
				<div>
					<p class="px-3 mb-3 text-[11px] font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Email</p>
					<div class="space-y-1">
						<a href="#compose" class="nav-link flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-gray-500 hover:bg-brand-50 hover:text-brand-500 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-white transition">
							<span class="material-symbols-outlined text-xl">send</span>Compose
