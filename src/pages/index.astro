			// ---- Schedule campaign (Utah / Mountain Time) ----
			let _when = "now";

			function setWhen(mode) {
				_when = mode;
				const base = "flex-1 inline-flex items-center justify-center gap-1.5 rounded-md px-3 py-1.5 text-sm transition";
				const active = base + " bg-white text-gray-800 font-semibold shadow-theme-xs dark:bg-gray-900 dark:text-white/90";
				const idle = base + " font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white";
				document.getElementById("when-now").className = mode === "now" ? active : idle;
				document.getElementById("when-later").className = mode === "later" ? active : idle;
				document.getElementById("schedule-wrap").classList.toggle("hidden", mode !== "later");
				document.getElementById("send-btn-label").textContent = mode === "later" ? "Schedule campaign" : "Send campaign";
				document.getElementById("send-btn-icon").textContent = mode === "later" ? "schedule" : "send";
				// First switch to Schedule: default to tomorrow 9:00 AM (Utah).
				if (mode === "later" && !document.getElementById("schedule-at").value) {
					dtpPreset("tomorrow9", true);
				}
			}

			// Interpret a datetime-local string ("YYYY-MM-DDTHH:mm") as a wall-clock
			// time in America/Denver (Utah) and return the absolute epoch ms — so the
			// scheduled time means Utah time no matter where the admin's browser is.
			function denverEpochFromWall(localStr) {
				if (!localStr || localStr.indexOf("T") === -1) return NaN;
				const [datePart, timePart] = localStr.split("T");
				const [Y, M, D] = datePart.split("-").map(Number);
				const [h, m] = timePart.split(":").map(Number);
				const guess = Date.UTC(Y, M - 1, D, h, m);
				const fmt = new Intl.DateTimeFormat("en-US", {
					timeZone: "America/Denver", year: "numeric", month: "2-digit", day: "2-digit",
					hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false,
				});
				const p = {};
				for (const part of fmt.formatToParts(new Date(guess))) p[part.type] = part.value;
				const wallAsUTC = Date.UTC(+p.year, +p.month - 1, +p.day, +p.hour % 24, +p.minute, +p.second);
				const offset = wallAsUTC - guess; // Denver = UTC + offset
				return guess - offset;
			}

			function updateScheduleEcho() {
				const v = document.getElementById("schedule-at").value;
				const echo = document.getElementById("schedule-echo");
				const epoch = denverEpochFromWall(v);
				if (!v || isNaN(epoch)) {
					echo.className = "text-xs text-gray-400 dark:text-gray-500 mt-1.5";
					echo.textContent = "Sends automatically at this Mountain Time (checked every ~5 min).";
					return;
				}
				const when = new Date(epoch).toLocaleString("en-US", {
					month: "short", day: "numeric", year: "numeric", hour: "numeric", minute: "2-digit",
					timeZone: "America/Denver",
				});
				if (epoch <= Date.now()) {
					echo.className = "text-xs text-error-500 mt-1.5";
					echo.textContent = "That time is in the past — pick a future time.";
				} else {
					echo.className = "text-xs text-gray-500 dark:text-gray-400 mt-1.5";
					echo.textContent = "Sends " + when + " MT — automatically (checked every ~5 min).";
				}
			}

			// ---- Modern date & time picker (all values are Utah wall-clock) ----
			const MONTHS = ["January","February","March","April","May","June","July","August","September","October","November","December"];
			const DAYS_SHORT = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
			const MONTHS_SHORT = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

			/** Current wall-clock date/time in America/Denver. */
			function denverNowParts() {
				const fmt = new Intl.DateTimeFormat("en-US", {
					timeZone: "America/Denver", year: "numeric", month: "2-digit", day: "2-digit",
					hour: "2-digit", minute: "2-digit", hour12: false,
				});
				const p = {};
				for (const part of fmt.formatToParts(new Date())) p[part.type] = part.value;
				return { y: +p.year, m: +p.month - 1, d: +p.day, h: +p.hour % 24, min: +p.minute };
			}

			const _now0 = denverNowParts();
			const dtp = {
				open: false,
				viewY: _now0.y, viewM: _now0.m,          // month being displayed
				selY: null, selM: null, selD: null,       // selected day
				hour12: 9, minute: 0, ampm: "AM",         // selected time
			};

			function dtpInitTimeSelects() {
				const hourSel = document.getElementById("dtp-hour");
				const minSel = document.getElementById("dtp-min");
				if (!hourSel || hourSel.options.length) return;
				for (let h = 1; h <= 12; h++) {
					const o = document.createElement("option");
					o.value = String(h); o.textContent = String(h);
					hourSel.appendChild(o);
				}
				for (let m = 0; m < 60; m += 5) {
					const o = document.createElement("option");
					o.value = String(m); o.textContent = String(m).padStart(2, "0");
					minSel.appendChild(o);
				}
				hourSel.value = String(dtp.hour12);
				minSel.value = String(dtp.minute);
				hourSel.addEventListener("change", () => { dtp.hour12 = +hourSel.value; dtpSync(); });
				minSel.addEventListener("change", () => { dtp.minute = +minSel.value; dtpSync(); });
			}

			function dtpToggle() {
				const pop = document.getElementById("dtp");
				dtp.open = !dtp.open;
				pop.classList.toggle("hidden", !dtp.open);
				if (dtp.open) {
					dtpInitTimeSelects();
					if (dtp.selY != null) { dtp.viewY = dtp.selY; dtp.viewM = dtp.selM; }
					dtpRender();
				}
			}

			function dtpPrev() { dtp.viewM--; if (dtp.viewM < 0) { dtp.viewM = 11; dtp.viewY--; } dtpRender(); }
			function dtpNext() { dtp.viewM++; if (dtp.viewM > 11) { dtp.viewM = 0; dtp.viewY++; } dtpRender(); }

			function dtpSetAmPm(p) {
				dtp.ampm = p;
				const am = document.getElementById("dtp-am");
				const pm = document.getElementById("dtp-pm");
				const on = "rounded-md px-2.5 py-1 text-xs font-semibold bg-brand-500 text-white transition";
				const off = "rounded-md px-2.5 py-1 text-xs font-medium text-gray-500 dark:text-gray-400 transition";
				am.className = p === "AM" ? on : off;
				pm.className = p === "PM" ? on : off;
				dtpSync();
			}

			function dtpRender() {
				document.getElementById("dtp-month-label").textContent = MONTHS[dtp.viewM] + " " + dtp.viewY;
				const grid = document.getElementById("dtp-days");
				grid.innerHTML = "";
				const today = denverNowParts();
				const firstDow = new Date(Date.UTC(dtp.viewY, dtp.viewM, 1)).getUTCDay();
				const daysInMonth = new Date(Date.UTC(dtp.viewY, dtp.viewM + 1, 0)).getUTCDate();
				for (let i = 0; i < firstDow; i++) grid.appendChild(document.createElement("span"));
				for (let d = 1; d <= daysInMonth; d++) {
					const btn = document.createElement("button");
					btn.type = "button";
					btn.textContent = String(d);
					const isPast =
						dtp.viewY < today.y ||
						(dtp.viewY === today.y && dtp.viewM < today.m) ||
						(dtp.viewY === today.y && dtp.viewM === today.m && d < today.d);
					const isToday = dtp.viewY === today.y && dtp.viewM === today.m && d === today.d;
					const isSel = dtp.selY === dtp.viewY && dtp.selM === dtp.viewM && dtp.selD === d;
					let cls = "h-9 w-full rounded-lg text-sm transition ";
					if (isPast) cls += "text-gray-300 dark:text-gray-700 cursor-not-allowed";
					else if (isSel) cls += "bg-brand-500 text-white font-semibold";
					else if (isToday) cls += "text-brand-500 font-semibold border border-brand-300 hover:bg-gray-100 dark:hover:bg-white/[0.06]";
					else cls += "text-gray-600 dark:text-gray-300 font-medium hover:bg-gray-100 dark:hover:bg-white/[0.06]";
					btn.className = cls;
					if (!isPast) {
						btn.addEventListener("click", () => {
							dtp.selY = dtp.viewY; dtp.selM = dtp.viewM; dtp.selD = d;
							dtpRender(); dtpSync();
						});
					} else {
						btn.disabled = true;
					}
					grid.appendChild(btn);
				}
			}

			function dtpPreset(kind, silent) {
				const now = denverNowParts();
				let y = now.y, m = now.m, d = now.d, h12 = 9, mi = 0, ap = "AM";
				if (kind === "plus1h") {
					// One hour from now (Utah), minutes rounded up to :05.
					let h = now.h + 1, day = now.d;
					mi = Math.ceil(now.min / 5) * 5;
					if (mi >= 60) { mi = 0; h++; }
					if (h >= 24) { h -= 24; day++; }
					const dim = new Date(Date.UTC(now.y, now.m + 1, 0)).getUTCDate();
					if (day > dim) { day = 1; m = now.m + 1; if (m > 11) { m = 0; y++; } }
					d = day;
					ap = h >= 12 ? "PM" : "AM";
					h12 = h % 12 === 0 ? 12 : h % 12;
				} else if (kind === "tomorrow9") {
					const dim = new Date(Date.UTC(now.y, now.m + 1, 0)).getUTCDate();
					d = now.d + 1;
					if (d > dim) { d = 1; m = now.m + 1; if (m > 11) { m = 0; y++; } }
				} else if (kind === "monday9") {
					const dow = new Date(Date.UTC(now.y, now.m, now.d)).getUTCDay();
					let add = (8 - dow) % 7; if (add === 0) add = 7;
					const t = new Date(Date.UTC(now.y, now.m, now.d + add));
					y = t.getUTCFullYear(); m = t.getUTCMonth(); d = t.getUTCDate();
				}
				dtp.selY = y; dtp.selM = m; dtp.selD = d;
				dtp.viewY = y; dtp.viewM = m;
				dtp.hour12 = h12; dtp.minute = mi; dtp.ampm = ap;
				dtpInitTimeSelects();
				const hourSel = document.getElementById("dtp-hour");
				const minSel = document.getElementById("dtp-min");
				if (hourSel) hourSel.value = String(h12);
				if (minSel) minSel.value = String(mi);
				dtpSetAmPm(ap);
				if (dtp.open) dtpRender();
				if (!silent && !dtp.open) dtpToggle();
				dtpSync();
			}

			function dtpClear() {
				dtp.selY = dtp.selM = dtp.selD = null;
				document.getElementById("schedule-at").value = "";
				const label = document.getElementById("dtp-label");
				label.textContent = "Pick a date & time…";
				label.className = "truncate text-gray-400 dark:text-gray-500";
				if (dtp.open) dtpRender();
				updateScheduleEcho();
			}

			/** Write the selection to the hidden input + trigger label + echo. */
			function dtpSync() {
				if (dtp.selY == null) return;
				let h = dtp.hour12 % 12;
				if (dtp.ampm === "PM") h += 12;
				const val = dtp.selY + "-" + String(dtp.selM + 1).padStart(2, "0") + "-" +
					String(dtp.selD).padStart(2, "0") + "T" + String(h).padStart(2, "0") + ":" +
					String(dtp.minute).padStart(2, "0");
				document.getElementById("schedule-at").value = val;
				const dow = DAYS_SHORT[new Date(Date.UTC(dtp.selY, dtp.selM, dtp.selD)).getUTCDay()];
				const label = document.getElementById("dtp-label");
				label.textContent = dow + ", " + MONTHS_SHORT[dtp.selM] + " " + dtp.selD + ", " + dtp.selY +
					" · " + dtp.hour12 + ":" + String(dtp.minute).padStart(2, "0") + " " + dtp.ampm + " MT";
				label.className = "truncate font-medium text-gray-800 dark:text-white/90";
				updateScheduleEcho();
			}

			// Close the picker when clicking outside it.
			document.addEventListener("click", (e) => {
				if (!dtp.open) return;
				const root = document.getElementById("dtp-root");
				if (root && !root.contains(e.target)) {
					dtp.open = false;
					document.getElementById("dtp").classList.add("hidden");
				}
			});

			function showSendResult(ok, msg) {
				const result = document.getElementById("send-result");
				result.className = "rounded-lg px-4 py-3 text-sm " +
					(ok ? "bg-success-50 border border-success-200 text-success-700 dark:bg-success-500/10 dark:border-success-500/30 dark:text-success-500"
						: "bg-error-50 border border-error-200 text-error-700 dark:bg-error-500/10 dark:border-error-500/30 dark:text-error-400");
				result.textContent = msg;
			}

			function submitCampaign() {
				if (!sesConfigured) return;
				if (_when === "later") scheduleCampaign();
				else sendCampaign();
			}

			async function scheduleCampaign() {
				const templateId = document.getElementById("template").value;
				const audience = document.getElementById("audience").value;
				const discount = (document.getElementById("discount") || {}).value || "";
				const v = document.getElementById("schedule-at").value;
				const epoch = denverEpochFromWall(v);
				if (!v || isNaN(epoch)) { showSendResult(false, "Pick a date and time."); return; }
				if (epoch <= Date.now()) { showSendResult(false, "Pick a time in the future (Mountain Time)."); return; }
				const body = { action: "create", template_id: templateId, audience, scheduled_at: epoch };
				if (discount) body.variables = { discount_code: discount };
				const btn = document.getElementById("send-btn");
				const label = document.getElementById("send-btn-label");
				const prevLabel = label.textContent;
				btn.disabled = true;
				label.textContent = "Scheduling…";
				try {
					const res = await fetch("/api/email/schedule", {
						method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(body),
					});
					const data = await res.json();
					if (res.ok && data.ok) { location.reload(); return; }
					showSendResult(false, data.error || "Could not schedule.");
				} catch (e) {
					showSendResult(false, "Network error. Please try again.");
				}
				btn.disabled = false;
				label.textContent = prevLabel;
			}

			async function cancelCampaign(id) {
				if (!confirm("Cancel this scheduled campaign?")) return;
				try {
					const res = await fetch("/api/email/schedule", {
						method: "POST", headers: { "content-type": "application/json" },
						body: JSON.stringify({ action: "cancel", id }),
					});
					const data = await res.json();
					if (res.ok && data.ok) { location.reload(); return; }
					alert(data.error || "Could not cancel.");
				} catch (e) {
					alert("Network error. Please try again.");
				}
			}

			// Astro wraps an `is:inline` + `define:vars` script in an IIFE, so these
			// functions are NOT global by default — but the inline onclick/onchange/
			// oninput attributes in the markup resolve against `window`. Expose them.
			Object.assign(window, {
				updatePreview,
				sendCampaign,
				openTemplateEditor,
				closeTemplateEditor,
				updateEditorPreview,
				saveTemplate,
				deleteTemplate,
				openTestModal,
				closeTestModal,
				sendTest,
				setWhen,
				submitCampaign,
				scheduleCampaign,
				cancelCampaign,
				updateScheduleEcho,
				dtpToggle,
				dtpPrev,
				dtpNext,
				dtpSetAmPm,
				dtpPreset,
				dtpClear,
				sidebarToggle,
				toggleTheme,
			});

			// ---- Drag-to-resize divider between Compose and Preview ----
			(function setupSplitter() {
				const container = document.getElementById("cp-container");
				const splitter = document.getElementById("cp-splitter");
				const frame = document.getElementById("preview-frame");
				if (!container || !splitter) return;
				let dragging = false;

				splitter.addEventListener("pointerdown", (e) => {
					dragging = true;
					splitter.setPointerCapture(e.pointerId);
					document.body.style.userSelect = "none";
					if (frame) frame.style.pointerEvents = "none"; // don't let the iframe swallow moves
					e.preventDefault();
				});
				splitter.addEventListener("pointermove", (e) => {
					if (!dragging) return;
					const rect = container.getBoundingClientRect();
					let pct = ((e.clientX - rect.left) / rect.width) * 100;
					pct = Math.max(25, Math.min(75, pct));
					container.style.setProperty("--left-w", pct + "%");
				});
				const end = () => {
					if (!dragging) return;
					dragging = false;
					document.body.style.userSelect = "";
					if (frame) frame.style.pointerEvents = "";
				};
				splitter.addEventListener("pointerup", end);
				splitter.addEventListener("pointercancel", end);
				// Double-click the handle to reset to a 50/50 split.
				splitter.addEventListener("dblclick", () => container.style.setProperty("--left-w", "50%"));
			})();

			updatePreview();
		</script>
	</body>
</html>
