								<span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-50 text-brand-500 dark:bg-brand-500/15 dark:text-brand-400">
									<span class="material-symbols-outlined">monitoring</span>
								</span>
								<h3 class="font-semibold text-gray-800 dark:text-white/90">Analytics</h3>
							</div>
							<span class="text-xs text-gray-400 dark:text-gray-500">all-time</span>
						</div>
						{stats.total === 0 ? (
							<div class="bg-white rounded-2xl border border-gray-200 shadow-theme-xs px-6 py-12 text-center text-sm text-gray-400 dark:bg-white/[0.03] dark:border-gray-800 dark:text-gray-500">
