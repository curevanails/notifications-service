							"theme-lg": "0px 12px 16px -4px rgba(16, 24, 40, 0.08), 0px 4px 6px -2px rgba(16, 24, 40, 0.03)",
						},
					},
				},
			};
		</script>
		<style is:inline>
			.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20; vertical-align: middle; }
			html { scroll-behavior: smooth; }
			body { background: #F9FAFB; }
			html.dark body { background: #101828; }
			.nice-scroll::-webkit-scrollbar { width: 8px; height: 8px; }
			.nice-scroll::-webkit-scrollbar-thumb { background: #D0D5DD; border-radius: 8px; }
			.nice-scroll::-webkit-scrollbar-thumb:hover { background: #98A2B3; }
			html.dark .nice-scroll::-webkit-scrollbar-thumb { background: #344054; }
			html.dark .nice-scroll::-webkit-scrollbar-thumb:hover { background: #475467; }
