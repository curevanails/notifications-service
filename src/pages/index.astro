						<div class="w-px h-6 bg-gray-200 dark:bg-gray-700 mx-1"></div>
						<a href="/logout" title="Sign out" class="grid h-10 w-10 place-items-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 hover:text-gray-700 dark:bg-white/[0.03] dark:text-gray-400 dark:hover:bg-white/[0.06] transition">
							<span class="material-symbols-outlined text-lg">logout</span>
