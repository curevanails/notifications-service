								<thead class="text-xs font-semibold uppercase text-gray-500 bg-gray-50 border-b border-gray-200 dark:bg-white/[0.02] dark:border-gray-800 dark:text-gray-400">
									<tr>
										<th class="px-5 py-3 text-left whitespace-nowrap">Template</th>
										<th class="px-5 py-3 text-left whitespace-nowrap">Audience</th>
