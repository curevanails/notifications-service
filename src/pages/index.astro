											<td class="px-5 py-3.5">
												<span class={`${PILL} ${CAMPAIGN_STATUS_CLASS[c.status] ?? "bg-gray-100 text-gray-600 dark:bg-white/[0.03] dark:text-gray-400"}`}>{c.status}</span>
												{c.status === "sent" && c.total != null && (
													<span class="ml-1.5 text-xs text-gray-400">{c.sent}/{c.total}{c.failed ? ` · ${c.failed} failed` : ""}</span>
