									</select>
								</div>

								<div>
									<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Audience <span class="text-xs font-normal text-gray-400 dark:text-gray-500">— active subscribers only</span></label>
									<select id="audience" class="form-select w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90">
										<option value="all">All active — {counts.all}</option>
										<option value="waiting">Waiting — {counts.waiting}</option>
										<option value="invited">Invited — {counts.invited}</option>
										<option value="redeemed">Redeemed — {counts.redeemed}</option>
									</select>
								</div>

								<div id="discount-wrap" class="hidden">
									<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Shared discount code <span class="text-xs font-normal text-gray-400 dark:text-gray-500">— optional override</span></label>
									<input id="discount" type="text" placeholder="e.g. CUREVA15" oninput="updatePreview()" class="form-input w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 shadow-theme-xs focus:border-brand-300 focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90" />
									<p class="text-xs text-gray-400 dark:text-gray-500 mt-1.5">Leave blank to use each subscriber's own code from the waitlist.</p>
								</div>

								<div>
									<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">When</label>
									<div class="flex rounded-lg border border-gray-200 bg-gray-50 p-1 dark:border-gray-800 dark:bg-white/[0.03]">
										<button type="button" id="when-now" onclick="setWhen('now')"
											class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-md px-3 py-1.5 text-sm bg-white text-gray-800 font-semibold shadow-theme-xs transition dark:bg-gray-900 dark:text-white/90">
											<span class="material-symbols-outlined text-base">bolt</span>Send now
										</button>
										<button type="button" id="when-later" onclick="setWhen('later')"
											class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white transition">
											<span class="material-symbols-outlined text-base">event</span>Schedule
										</button>
									</div>
								</div>

								<div id="schedule-wrap" class="hidden">
									<label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Date &amp; time <span class="text-xs font-normal text-gray-400 dark:text-gray-500">— Utah (Mountain Time)</span></label>
									<input id="schedule-at" type="hidden" />
									<div id="dtp-root" class="relative">
										<button type="button" id="dtp-trigger" onclick="dtpToggle()"
