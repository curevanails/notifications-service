										<tr class="hover:bg-gray-50/70 dark:hover:bg-white/[0.02] transition">
											<td class="px-5 py-3.5 font-medium text-gray-800 dark:text-white/90">{templateName(c.template_id)}</td>
											<td class="px-5 py-3.5 text-gray-500 dark:text-gray-400">{AUDIENCE_LABEL[c.audience] ?? c.audience}</td>
