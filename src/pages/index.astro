					<div class="flex items-center gap-2">
						<span class="hidden md:inline-flex items-center gap-1.5 rounded-full bg-gray-50 border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 dark:bg-white/[0.03] dark:border-gray-800 dark:text-gray-300">
							<span class="material-symbols-outlined text-sm text-gray-400">group</span>{counts.all} subscribers
