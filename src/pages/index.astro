							<div class="flex items-center gap-2.5">
								<span class="grid h-9 w-9 place-items-center rounded-lg bg-blue-light-50 text-blue-light-700 dark:bg-blue-light-500/15 dark:text-blue-light-400">
									<span class="material-symbols-outlined">schedule</span>
								</span>
								<h3 class="font-semibold text-gray-800 dark:text-white/90">Scheduled campaigns</h3>
							</div>
							<span class="text-xs text-gray-400 dark:text-gray-500">times in Mountain Time (Utah)</span>
						</header>
						<div class="overflow-x-auto nice-scroll">
