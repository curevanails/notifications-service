												<span class="material-symbols-outlined text-lg">mail</span>
											</div>
											<div class="min-w-0">
												<p class="text-sm font-medium text-gray-800 dark:text-white/90 truncate">{t.name}</p>
												<p class="text-xs text-gray-400 dark:text-gray-500 truncate mt-0.5">{t.subject}</p>
											</div>
										</div>
										<div class="flex items-center gap-1.5 shrink-0">
