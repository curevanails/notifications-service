					</div>
					<nav class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1.5">
						<span class="material-symbols-outlined text-sm">home</span>
						<span>/</span>
						<span class="text-gray-800 dark:text-white/90 font-medium">Dashboard</span>
					</nav>
				</div>

				{!loadError && (
					<div id="cp-container" class="flex flex-col xl:flex-row gap-6 xl:gap-0 items-stretch scroll-mt-24" style="--left-w: 50%" >
