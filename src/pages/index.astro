											<span class="flex items-center gap-2 min-w-0">
												<span class="material-symbols-outlined text-base text-gray-400">calendar_month</span>
												<span id="dtp-label" class="truncate text-gray-400 dark:text-gray-500">Pick a date &amp; time…</span>
											</span>
											<span class="material-symbols-outlined text-base text-gray-400">expand_more</span>
										</button>

										{/* Calendar + time popover */}
										<div id="dtp" class="hidden absolute z-40 mt-2 left-0 w-full sm:w-[340px] rounded-xl bg-white border border-gray-200 shadow-theme-lg p-4 pop-in dark:bg-gray-900 dark:border-gray-800">
											<div class="flex items-center justify-between mb-2">
												<button type="button" onclick="dtpPrev()" class="grid h-8 w-8 place-items-center rounded-lg text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-white/[0.06] dark:hover:text-white transition">
													<span class="material-symbols-outlined text-base">chevron_left</span>
												</button>
												<p id="dtp-month-label" class="text-sm font-semibold text-gray-800 dark:text-white/90"></p>
												<button type="button" onclick="dtpNext()" class="grid h-8 w-8 place-items-center rounded-lg text-gray-400 hover:bg-gray-100 hover:text-gray-700 dark:hover:bg-white/[0.06] dark:hover:text-white transition">
													<span class="material-symbols-outlined text-base">chevron_right</span>
												</button>
											</div>
											<div class="grid grid-cols-7 text-center text-[11px] font-semibold text-gray-400 mb-1">
												<span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
											</div>
											<div id="dtp-days" class="grid grid-cols-7 gap-0.5"></div>

											<div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-800 flex items-center gap-2">
												<span class="material-symbols-outlined text-base text-gray-400">schedule</span>
												<select id="dtp-hour" class="form-select rounded-lg border border-gray-300 bg-transparent py-1.5 pl-3 pr-8 text-sm font-medium text-gray-800 shadow-theme-xs focus:border-brand-300 focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90"></select>
												<span class="text-gray-400 font-semibold">:</span>
												<select id="dtp-min" class="form-select rounded-lg border border-gray-300 bg-transparent py-1.5 pl-3 pr-8 text-sm font-medium text-gray-800 shadow-theme-xs focus:border-brand-300 focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90"></select>
												<div class="ml-auto flex rounded-lg border border-gray-200 p-0.5 dark:border-gray-700">
													<button type="button" id="dtp-am" onclick="dtpSetAmPm('AM')" class="rounded-md px-2.5 py-1 text-xs font-semibold bg-brand-500 text-white transition">AM</button>
													<button type="button" id="dtp-pm" onclick="dtpSetAmPm('PM')" class="rounded-md px-2.5 py-1 text-xs font-medium text-gray-500 dark:text-gray-400 transition">PM</button>
												</div>
											</div>

											<div class="mt-3 flex flex-wrap gap-1.5">
												<button type="button" onclick="dtpPreset('plus1h')" class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 hover:border-brand-300 hover:text-brand-500 dark:border-gray-700 dark:text-gray-400 dark:hover:border-brand-700 dark:hover:text-brand-400 transition">In 1 hour</button>
												<button type="button" onclick="dtpPreset('tomorrow9')" class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 hover:border-brand-300 hover:text-brand-500 dark:border-gray-700 dark:text-gray-400 dark:hover:border-brand-700 dark:hover:text-brand-400 transition">Tomorrow 9 AM</button>
												<button type="button" onclick="dtpPreset('monday9')" class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-medium text-gray-600 hover:border-brand-300 hover:text-brand-500 dark:border-gray-700 dark:text-gray-400 dark:hover:border-brand-700 dark:hover:text-brand-400 transition">Monday 9 AM</button>
											</div>

											<div class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-800 flex items-center justify-between">
												<button type="button" onclick="dtpClear()" class="text-xs font-medium text-gray-400 hover:text-error-500 transition">Clear</button>
												<button type="button" onclick="dtpToggle()" class="rounded-lg bg-brand-500 px-4 py-1.5 text-xs font-semibold text-white hover:bg-brand-600 transition">Done</button>
											</div>
										</div>
									</div>
									<p id="schedule-echo" class="text-xs text-gray-400 dark:text-gray-500 mt-1.5">Sends automatically at this Mountain Time (checked every ~5 min).</p>
								</div>

								<button id="send-btn" type="button" onclick="submitCampaign()" disabled={!sesConfigured}
									class="w-full inline-flex items-center justify-center gap-2 rounded-lg bg-brand-500 px-4 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600 transition disabled:opacity-40 disabled:cursor-not-allowed">
									<span class="material-symbols-outlined text-base" id="send-btn-icon">send</span><span id="send-btn-label">Send campaign</span>
								</button>
								<div id="send-result" class="hidden rounded-lg px-4 py-3 text-sm"></div>
							</div>
						</section>

						{/* ---- Drag-to-resize divider (xl+ only) ---- */}
						<div id="cp-splitter" title="Drag to resize" class="hidden xl:flex items-center justify-center w-6 shrink-0 cursor-col-resize group select-none touch-none">
							<div class="h-14 w-1 rounded-full bg-gray-300 group-hover:bg-brand-500 group-hover:h-20 transition-all dark:bg-gray-700"></div>
						</div>

						{/* ---- Preview ---- */}
