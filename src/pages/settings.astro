---
import { env } from "cloudflare:workers";
import {
	RECRUIT_NOTIFY_TO,
	getSetting,
	parseRecipients,
	recipientsValid,
	setSetting,
} from "../utils/app-settings";

// Server-rendered, auth-gated by src/middleware.ts (path listed as protected).
export const prerender = false;

const db = env.DB as D1Database;

let saved = false;
let error: string | null = null;
let value = (await getSetting(db, RECRUIT_NOTIFY_TO)) ?? "";

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const raw = String(form.get("recruit_notify_to") ?? "").trim();
	if (!recipientsValid(raw)) {
		error = "One or more addresses look invalid. Separate multiple with commas.";
		value = raw;
	} else {
		// Store normalised (comma-joined) so the read side is predictable.
		const normalised = parseRecipients(raw).join(", ");
		await setSetting(db, RECRUIT_NOTIFY_TO, normalised);
		value = normalised;
		saved = true;
	}
}

const count = parseRecipients(value).length;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Settings · CureVà Notify</title>
		<script is:inline>
			(function () {
				try {
					const saved = localStorage.getItem("theme");
					const sysDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
					if (saved === "dark" || (!saved && sysDark)) document.documentElement.classList.add("dark");
				} catch (_) {}
			})();
		</script>
		<script is:inline src="https://cdn.tailwindcss.com?plugins=forms"></script>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<script is:inline id="tailwind-config">
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						fontFamily: { sans: ["Outfit", "system-ui", "sans-serif"] },
						colors: {
							brand: { 50: "#ECF3FF", 100: "#DDE9FF", 300: "#9CB9FF", 500: "#465FFF", 600: "#3641F5", 700: "#2A31D8" },
							curva: { DEFAULT: "#3a656e", dark: "#2f545c" },
						},
					},
				},
			};
		</script>
	</head>
	<body class="min-h-screen bg-gray-50 font-sans text-gray-800 antialiased dark:bg-gray-950 dark:text-gray-200">
		<main class="mx-auto max-w-2xl px-4 py-10 sm:py-14">
			<a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-brand-500">
				← Back to dashboard
			</a>

			<h1 class="mt-5 text-2xl font-semibold text-gray-900 dark:text-white sm:text-3xl">Settings</h1>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Operator settings for the CureVà notify service.</p>

			<section class="mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03]">
				<h2 class="text-base font-semibold text-gray-900 dark:text-white">Recruit alerts</h2>
				<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
					Who receives an email when a candidate submits the application form at
					<code class="rounded bg-gray-100 px-1 py-0.5 text-xs dark:bg-white/[0.06]">/recruit/apply</code>.
					Separate multiple addresses with commas.
				</p>

				{saved && (
					<div class="mt-4 flex items-center gap-2 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 dark:border-green-500/20 dark:bg-green-500/10 dark:text-green-400">
						Saved. {count === 0 ? "Alerts are now OFF (no recipients)." : `${count} recipient${count === 1 ? "" : "s"} will be notified.`}
					</div>
				)}
				{error && (
					<div class="mt-4 flex items-center gap-2 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-500/20 dark:bg-red-500/10 dark:text-red-400">
						{error}
					</div>
				)}

				<form method="POST" class="mt-5">
					<label for="recruit_notify_to" class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-300">
						Notify addresses
					</label>
					<input
						id="recruit_notify_to"
						name="recruit_notify_to"
						type="text"
						value={value}
						placeholder="you@example.com, partner@example.com"
						autocomplete="off"
						class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 text-sm text-gray-800 shadow-sm transition placeholder:text-gray-400 focus:border-brand-300 focus:outline-none focus:ring-4 focus:ring-brand-500/10 dark:border-gray-700 dark:text-white/90"
					/>
					<p class="mt-2 text-xs text-gray-400 dark:text-gray-500">
						Leave blank to turn alerts off. In the SES sandbox, each address must be verified in AWS.
					</p>
					<button
						type="submit"
						class="mt-4 inline-flex h-11 items-center rounded-lg bg-brand-500 px-5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-600"
					>
						Save
					</button>
					<a href="/recruit-alerts" class="ml-3 text-sm font-medium text-brand-500 hover:text-brand-600">View recruit alerts →</a>
				</form>
			</section>
		</main>
	</body>
</html>
