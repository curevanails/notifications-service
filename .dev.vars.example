# AWS SES (email sending). Copy to `.dev.vars` and fill to test real sends locally.
# In production set these as Worker secrets (see docs/EMAIL.md), NOT vars.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Public origin used to build unsubscribe links in emails (optional).
# PUBLIC_SITE_URL=https://curevanails-tech.workers.dev

# Admin dashboard auth. ADMIN_PASSWORD is required to enable /admin (if unset,
# the admin area returns 404). ADMIN_USERNAME is optional (defaults to "admin").
ADMIN_PASSWORD=devpassword
# ADMIN_USERNAME=admin
# SESSION_SECRET: dedicated high-entropy key for signing session cookies, kept
# separate from ADMIN_PASSWORD. Strongly recommended — without it, a captured
# cookie can be used to brute-force ADMIN_PASSWORD offline. Generate one with:
#   openssl rand -hex 32
# SESSION_SECRET=
